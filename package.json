{
  "name": "@multichain-dev/multichain-sdk",
  "version": "0.1.0",
  "description": "Headless SDK for cross-chain token swaps to Gnosis chain and Swarm postage batch creation",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "check": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@relayprotocol/relay-sdk": "^3.0.0",
    "@upcoming/multichain-library": "^0.10.0",
    "cafe-utility": "^33.8.0",
    "tslib": "^2.8.1",
    "viem": "^2.38.1"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.9.0",
    "vitest": "^3.0.0"
  },
  "peerDependencies": {
    "@solana/web3.js": "^2.0.0"
  },
  "peerDependenciesMeta": {
    "@solana/web3.js": {
      "optional": true
    }
  },
  "license": "MIT"
}
